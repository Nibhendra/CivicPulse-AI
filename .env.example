# ============================================================
# CivicPulse AI — Environment Variable Reference
# ============================================================
# Copy this file to .env.local (frontend) and server/.env (server).
# NEVER commit .env.local or server/.env — both are gitignored.
# ============================================================

# ── Server-side ONLY (server/.env) ──────────────────────────
# These MUST stay in server/.env and must NEVER be prefixed with VITE_
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite

# ── Frontend environment (.env.local) ───────────────────────
# Firebase — restricted by Firestore security rules (safe to expose)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123:web:abc

# Cloudinary — unsigned upload only (cloud name + unsigned preset are safe)
VITE_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_cloudinary_unsigned_preset

# API base URL:
# - Local dev: leave empty — Vite proxies /api/* → localhost:3001
# - Production on same server: leave empty
# - External API server: set full URL e.g. https://your-server.onrender.com
VITE_API_BASE_URL=
