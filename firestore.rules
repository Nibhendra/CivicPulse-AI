rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // ── Issues ────────────────────────────────────────────────────────────────
    match /issues/{issueId} {
      allow read: if request.auth != null;

      // Create: authenticated, must set reporterId = own UID
      allow create: if request.auth != null
        && request.resource.data.reporterId == request.auth.uid;

      // Update: allow if any of the following:
      allow update: if request.auth != null && (

        // 1. Upvote toggle (only upvotes/upvoterIds change)
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['upvotes', 'upvoterIds', 'updatedAt'])

        // 2. Community verification actions (any auth user, toggle-able arrays)
        || request.resource.data.diff(resource.data).affectedKeys()
          .hasAny([
            'confirmations', 'confirmedBy',
            'fakeReports', 'fakeReportedBy',
            'resolvedReports', 'resolvedBy',
            'duplicateReports', 'duplicateReportedBy',
            'communityScore', 'verificationStatus',
            'updatedAt'
          ])

        // 3. Issue owner can update any field (AI results, complaint, etc.)
        || resource.data.reporterId == request.auth.uid

        // 4. Authority/admin status updates (demo: any authenticated user)
        || request.resource.data.diff(resource.data).affectedKeys()
          .hasAny([
            'status', 'authorityStatus', 'authorityNote',
            'lastStatusUpdatedAt', 'lastStatusUpdatedBy',
            'timeline', 'resolvedAt', 'updatedAt'
          ])
      );

      allow delete: if false;

      // Comments
      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.resource.data.userId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // ── Departments (read-only) ───────────────────────────────────────────────
    match /departments/{deptId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
