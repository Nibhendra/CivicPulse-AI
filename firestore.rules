rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // ── Issues ────────────────────────────────────────────────────────────────
    match /issues/{issueId} {
      allow read: if request.auth != null;

      // Create: authenticated, must set reporterId = own UID
      allow create: if request.auth != null
        && request.resource.data.reporterId == request.auth.uid;

      // Update: allow if any of the following:
      allow update: if request.auth != null && (

        // 1. Upvote toggle: any user EXCEPT reporter
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['upvotes', 'upvoterIds', 'updatedAt'])
         && request.auth.uid != resource.data.reporterId)

        // 2. Community verification: any user EXCEPT reporter
        || (request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'confirmations', 'confirmedBy',
              'fakeReports', 'fakeReportedBy',
              'resolvedReports', 'resolvedBy',
              'duplicateReports', 'duplicateReportedBy',
              'communityScore', 'verificationStatus',
              'updatedAt'
            ])
            && request.auth.uid != resource.data.reporterId)

        // 3. Issue owner can update AI results/complaint, but NOT upvotes/verifications/authority status
        || (resource.data.reporterId == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'aiCategory', 'aiSeverity', 'aiDamageDescription', 'aiConfidence',
              'isValidCivicIssue', 'severityScore', 'urgencyScore', 'priorityLevel',
              'assignedDepartment', 'suggestedNextAction', 'publicRisk',
              'isDuplicate', 'duplicateOf', 'duplicateScore', 'agentLog',
              'aiProcessed', 'aiProcessedAt', 'formalComplaint', 'complaintGeneratedAt',
              'status', 'timeline', 'updatedAt'
            ])
            && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['status']) || request.resource.data.status == 'under_review'))

        // 4. Authority/admin status updates (restricted to admin/authority email list)
        || (request.auth.token.email in [
              'admin@gmail.com',
              'admin@civicpulse.org',
              'authority@civicpulse.org'
            ]
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                'status', 'authorityStatus', 'authorityNote', 'assignedDepartment',
                'lastStatusUpdatedAt', 'lastStatusUpdatedBy',
                'timeline', 'resolvedAt', 'updatedAt'
              ]))
      );

      allow delete: if false;

      // Comments
      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.resource.data.userId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // ── Departments (read-only) ───────────────────────────────────────────────
    match /departments/{deptId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
